# Cookie署名用（32文字以上推奨）
LP_AUTH_SECRET="change_me_to_a_long_random_string_32+"

# 学生配布パスワード
# ※強制ログアウトなし：既に認証済み端末は最大30日入れます
LP_ACCESS_PASSWORD="ABC123"

# 背景/ロゴ（管理者が決める）
# public を使うなら "/bg.jpeg" "/logo.png"
LP_BG_URL="/bg.jpeg"
LP_LOGO_URL="/logo.png"

# LPから飛ばす2プロジェクト（固定）
NEXT_PUBLIC_INTERVIEW_POD_URL="https://interview-pod.example.com"
NEXT_PUBLIC_ES_TRAINER_URL="https://es-trainer.example.com"